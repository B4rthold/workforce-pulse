# =============================================================================
# Workforce Pulse — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing API keys or secrets.
# =============================================================================

# Data mode: "true" = use stub data (no backend required), "false" = call real APIs
NEXT_PUBLIC_USE_STUBS=true

# Base URL for backend API (used when USE_STUBS=false)
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Montgomery ArcGIS open data endpoints
# Used by /api/workforce-data and services when USE_STUBS=false
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ARCGIS_911_URL=https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/911_Calls_Data/FeatureServer/0
NEXT_PUBLIC_ARCGIS_STATIONS_URL=https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/Story_Map___Live__1__WFL1/FeatureServer
NEXT_PUBLIC_ARCGIS_PERMITS_URL=https://gis.montgomeryal.gov/server/rest/services/HostedDatasets/Construction_Permits/FeatureServer/0
NEXT_PUBLIC_ARCGIS_EDUCATION_URL=https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/Education_Facility/FeatureServer/0
NEXT_PUBLIC_ARCGIS_POPULATION_URL=https://services7.arcgis.com/xNUwUjOJqYE54USz/arcgis/rest/services/Daily_Population_Trends/FeatureServer/0

# -----------------------------------------------------------------------------
# JobAps — City of Montgomery official job listings (RSS feed, no auth)
# Used by automatic job aggregator.
# -----------------------------------------------------------------------------
JOBAPS_RSS_URL=https://jobapscloud.com/MGM/rss.asp

# -----------------------------------------------------------------------------
# USAJOBS — Federal job listings (free API key at developer.usajobs.gov)
# Used by automatic job aggregator for Montgomery-area federal jobs.
# -----------------------------------------------------------------------------
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your-email@example.com

# -----------------------------------------------------------------------------
# Bright Data — Scraping Browser (Playwright via CDP)
# Required for POST /api/jobs/scrape (Indeed job scraping).
# Get your WebSocket URL from Bright Data dashboard (Scraping Browser zone).
# Server-side only — never expose to client.
# -----------------------------------------------------------------------------
BRIGHT_DATA_BROWSER_WSS=wss://brd-customer-<YOUR_CUSTOMER_ID>-zone-scraping_browser1:<YOUR_PASSWORD>@brd.superproxy.io:9222

# -----------------------------------------------------------------------------
# Bright Data — Dataset API (optional, alternative to Scraping Browser)
# Used for pre-built datasets like Indeed/LinkedIn if configured.
# -----------------------------------------------------------------------------
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_INDEED_DATASET_ID=
BRIGHT_DATA_LINKEDIN_DATASET_ID=
